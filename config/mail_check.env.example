# IMAP mailbox settings
IMAP_HOST=imap.example.net
IMAP_PORT=993
IMAP_USER=monitor@example.net
IMAP_PASSWORD=CHANGE_ME
IMAP_MAILBOX=INBOX

# Match criteria
MAIL_SUBJECT_CONTAINS=IcingaMail:
MAIL_FROM_CONTAINS=
MAIL_HEADER_TEMPLATE_FILE=/path/to/check_emails/vorlagen/mail_header.txt
MAIL_TEMPLATE_HEADERS=Subject,From,To,Return-Path,X-KasLoop
MAIL_INCLUDE_SEEN=0
MAIL_DELETE_MATCH=1

# Icinga2 API settings (passive result)
MAIL_DEBUG_ICINGA=0
MAIL_ICINGA_DRY_RUN=0
ICINGA_URL=https://icinga.example.net:5665
ICINGA_USER=root
ICINGA_PASSWORD=CHANGE_ME
ICINGA_HOST=my-mail-check-host
ICINGA_SERVICE=mail-heartbeat
ICINGA_VERIFY_TLS=1

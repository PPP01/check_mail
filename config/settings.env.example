# IMAP mailbox settings
IMAP_HOST=imap.example.net
IMAP_PORT=993
IMAP_USER=monitor@example.net
IMAP_PASSWORD=CHANGE_ME
IMAP_MAILBOX=INBOX
# JWT secret for send/check validation (same value for sender and receiver, min 32 chars)
MAIL_CHECK_JWT_SECRET=CHANGE_ME_JWT_SECRET
# Maximum accepted JWT age in seconds at receive time
MAIL_CHECK_JWT_MAX_AGE_SECONDS=86400
# Include already seen mails (1=yes, 0=no)
MAIL_INCLUDE_SEEN=0
# Delete matching mails after successful match (1=yes, 0=no)
MAIL_DELETE_MATCH=0

# Icinga2 API settings (passive result)
# Print Icinga request details (1=yes, 0=no)
ICINGA_DEBUG=0
# Show Icinga password in debug curl output (1=yes, 0=no, TTY only)
ICINGA_DEBUG_SHOW_PASSWORD=0
# Do not submit to Icinga, only simulate submit (1=yes, 0=no)
ICINGA_DRY_RUN=0
# Enable passive Icinga submit in check command (1=yes, 0=no)
ICINGA_PASSIVE_CHECK=1
ICINGA_URL=https://icinga.example.net:5665
ICINGA_USER=root
ICINGA_PASSWORD=CHANGE_ME
ICINGA_HOST=my-mail-check-host
ICINGA_SERVICE=mail-heartbeat
ICINGA_VERIFY_TLS=1

# Mail send settings (send command, mostly optional)
MAIL_SEND_BACKEND=sendmail
MAIL_SEND_TO=monitor@example.net
MAIL_SEND_FROM=monitor@example.net
MAIL_SEND_SUBJECT=IcingaMail: Send test
MAIL_SEND_BODY=IcingaMail Send test

# Backend sendmail
MAIL_SEND_SENDMAIL_COMMAND=/usr/sbin/sendmail -t -i

# Backend mail
MAIL_SEND_MAIL_COMMAND=/usr/bin/mail

# Backend smtp
MAIL_SEND_SMTP_HOST=smtp.example.net
MAIL_SEND_SMTP_PORT=587
MAIL_SEND_SMTP_USER=
MAIL_SEND_SMTP_PASSWORD=
MAIL_SEND_SMTP_STARTTLS=1
MAIL_SEND_SMTP_SSL=0

# Required default match criteria profile (relative to project root or absolute path)
MAIL_ACTIVE_CONFIG=config/match_criteria_example.env

# Example config: Icinga receive (active receive check only, no passive submit)
# Typical command: ./mail_check.py -c config/settings.icinga_receive.env.example check --no-icinga-submit

# IMAP mailbox settings
IMAP_HOST=imap.example.net
IMAP_PORT=993
IMAP_USER=monitor@example.net
IMAP_PASSWORD=CHANGE_ME
IMAP_MAILBOX=INBOX

# JWT secret for send/check validation (same value for sender and receiver, min 32 chars)
MAIL_CHECK_JWT_SECRET=CHANGE_ME_JWT_SECRET
# Maximum accepted JWT age in seconds at receive time
MAIL_CHECK_JWT_MAX_AGE_SECONDS=86400
# Include already seen mails (1=yes, 0=no)
MAIL_INCLUDE_SEEN=0
# Delete matching mails after successful match (1=yes, 0=no)
MAIL_DELETE_MATCH=0

ICINGA_PASSIVE_CHECK=0

# Required match criteria profile for check/email
MAIL_ACTIVE_CONFIG=config/match_criteria_example.env

# Example config: Icinga send (active send test)
# Typical command: ./mail_check.py -c config/settings.icinga_send.env.example send


# JWT secret for send/check validation (same value for sender and receiver, min 32 chars)
MAIL_CHECK_JWT_SECRET=CHANGE_ME_JWT_SECRET
# Maximum accepted JWT age in seconds at receive time
MAIL_CHECK_JWT_MAX_AGE_SECONDS=86400

# Mail send settings (send command)
MAIL_SEND_BACKEND=sendmail
MAIL_SEND_TO=monitor@example.net
MAIL_SEND_FROM=monitor@example.net
MAIL_SEND_SUBJECT=IcingaMail: Send test
MAIL_SEND_BODY=IcingaMail Send test

# Backend sendmail
MAIL_SEND_SENDMAIL_COMMAND=/usr/sbin/sendmail -t -i

# Backend mail
MAIL_SEND_MAIL_COMMAND=/usr/bin/mail

# Backend smtp
MAIL_SEND_SMTP_HOST=smtp.example.net
MAIL_SEND_SMTP_PORT=587
MAIL_SEND_SMTP_USER=
MAIL_SEND_SMTP_PASSWORD=
MAIL_SEND_SMTP_STARTTLS=1
MAIL_SEND_SMTP_SSL=0

